# ============================================================
# ATALAYA PANÓPTICA — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env (nunca commitear .env)
# 2. Rellena cada valor con tus credenciales reales
# 3. En GitHub Actions: Settings > Secrets and variables > Actions
#    Agrega cada variable como un "Repository Secret"
# ============================================================

# --- SUPABASE ---
# Obtener en: https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=eyJ...              # Clave pública (frontend, lectura)
SUPABASE_SERVICE_KEY=eyJ...           # Clave privada (backend Python, escritura) — NUNCA exponer

# --- GROQ (IA) ---
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile   # Modelo a usar (o llama3-8b-8192 para más velocidad)

# --- API DE X / TWITTER (Agente Viral) ---
# Obtener en: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# --- CONFIGURACIÓN DEL SISTEMA ---
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
MAX_ITEMS_PER_RUN=10                  # Cuántos ítems procesa el Detective por ejecución
CONFIDENCE_THRESHOLD_ANOMALY=0.60    # Mínimo para crear una anomalía
CONFIDENCE_THRESHOLD_VIRAL=0.85      # Mínimo para generar contenido viral
